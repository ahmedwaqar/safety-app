{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["bun"]
  },
  "include": ["app/**/*.ts", "scripts/**/*.ts"]
}
